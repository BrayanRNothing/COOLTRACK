generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              String          @id @default(uuid()) @db.Uuid
  nombres         String
  apellidoPaterno String          @map("apellido_paterno")
  apellidoMaterno String          @map("apellido_materno")
  email           String          @unique
  username        String          @unique
  telefono        String?
  passwordHash    String          @map("password_hash")
  rol             RolUsuario
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  asignaciones    Asignacion[]
  mantenimientos  Mantenimiento[]

  @@map("usuarios")
}

model Cliente {
  id             String            @id @default(uuid()) @db.Uuid
  numeroCliente  String            @unique @map("numero_cliente")
  nombreOEmpresa String            @map("nombre_o_empresa")
  ciudad         String?
  telefono       String?
  email          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  asignaciones   Asignacion[]
  climas         ClimaIndustrial[]

  @@map("clientes")
}

model ClimaIndustrial {
  id              String          @id @default(uuid()) @db.Uuid
  numeroSerie     String          @unique @map("numero_serie")
  marca           String
  modelo          String
  fechaAplicacion DateTime        @map("fecha_aplicacion") @db.Date
  geolocalizacion String?
  idCliente       String          @map("id_cliente") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  cliente         Cliente         @relation(fields: [idCliente], references: [id])
  mantenimientos  Mantenimiento[]

  @@index([idCliente])
  @@map("climas_industriales")
}

model Asignacion {
  id              String           @id @default(uuid()) @db.Uuid
  idCliente       String           @map("id_cliente") @db.Uuid
  idTecnico       String           @map("id_tecnico") @db.Uuid
  notas           String?
  fechaProgramada DateTime         @map("fecha_programada")
  estado          EstadoAsignacion @default(PENDIENTE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  cliente         Cliente          @relation(fields: [idCliente], references: [id])
  tecnico         Usuario          @relation(fields: [idTecnico], references: [id])
  mantenimientos  Mantenimiento[]

  @@index([idCliente])
  @@index([idTecnico])
  @@map("asignaciones")
}

model Mantenimiento {
  id                 String          @id @default(uuid()) @db.Uuid
  idClima            String          @map("id_clima") @db.Uuid
  idTecnico          String          @map("id_tecnico") @db.Uuid
  idAsignacion       String?         @map("id_asignacion") @db.Uuid
  fechaMantenimiento DateTime        @map("fecha_mantenimiento")
  foto1Url           String?         @map("foto_1_url")
  foto2Url           String?         @map("foto_2_url")
  foto3Url           String?         @map("foto_3_url")
  observaciones      String?
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  asignacion         Asignacion?     @relation(fields: [idAsignacion], references: [id])
  clima              ClimaIndustrial @relation(fields: [idClima], references: [id])
  tecnico            Usuario         @relation(fields: [idTecnico], references: [id])

  @@index([idClima])
  @@index([idTecnico])
  @@index([idAsignacion])
  @@index([fechaMantenimiento])
  @@map("mantenimientos")
}

enum RolUsuario {
  ADMIN
  TECNICO_CONTRATISTA
}

enum EstadoAsignacion {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
}
